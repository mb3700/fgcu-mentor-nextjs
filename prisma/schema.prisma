generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mentor {
  id                Int       @id @default(autoincrement())
  name              String
  status            String    @default("Available")
  businessName      String?   @map("business_name")
  title             String?
  location          String?
  phone             String?
  email             String?
  biography         String?   @db.Text
  fgcuAlumni        Boolean   @default(false) @map("fgcu_alumni")
  domainExpertise   String[]  @map("domain_expertise")
  sectorExpertise   String[]  @map("sector_expertise")
  programs          String[]
  workStatus        String?   @map("work_status")
  potentialSpeaker  Boolean   @default(false) @map("potential_speaker")
  potentialJudge    Boolean   @default(false) @map("potential_judge")
  mentorCoordinator String?   @map("mentor_coordinator")
  veteranStatus     Boolean   @default(false) @map("veteran_status")
  photoUrl          String?   @map("photo_url")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  interactions        Interaction[]
  sessionAttendances  SessionAttendee[]

  @@map("mentors")
  @@index([name])
  @@index([status])
}

model Interaction {
  id        Int      @id @default(autoincrement())
  mentorId  Int      @map("mentor_id")
  mentor    Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  type      String
  subject   String?
  notes     String?  @db.Text
  date      DateTime @default(now())
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("interactions")
  @@index([mentorId])
}

model MentorCircle {
  id          Int       @id @default(autoincrement())
  name        String
  coordinator String
  dayOfWeek   String    @map("day_of_week")
  startTime   String    @map("start_time")
  endTime     String    @map("end_time")
  semester    String
  location    String?
  notes       String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sessions CircleSession[]

  @@map("mentor_circles")
  @@index([semester])
  @@index([isActive])
}

model CircleSession {
  id        Int          @id @default(autoincrement())
  circleId  Int          @map("circle_id")
  circle    MentorCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  date      DateTime
  notes     String?      @db.Text
  cancelled Boolean      @default(false)
  createdAt DateTime     @default(now()) @map("created_at")

  attendees SessionAttendee[]

  @@map("circle_sessions")
  @@index([circleId])
  @@index([date])
}

model SessionAttendee {
  id        Int           @id @default(autoincrement())
  sessionId Int           @map("session_id")
  session   CircleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mentorId  Int           @map("mentor_id")
  mentor    Mentor        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  status    String        @default("scheduled")
  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([sessionId, mentorId])
  @@map("session_attendees")
  @@index([sessionId])
  @@index([mentorId])
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_sessions")
}
